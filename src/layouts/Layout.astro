---
import '@/global.css';

import { Font } from 'astro:assets';

import Background from './components/Background.astro';
import Header from './components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href="https://mauroviveros.com.ar" />
    <meta name="generator" content={Astro.generator} />

    <title>Mauro Viveros | Frontend Engineer</title>
    <meta
      name="description"
      content="Frontend Engineer with 5+ years building performant, accessible web applications. Based in Buenos Aires, Argentina."
    />

    <meta property="og:title" content="Mauro Viveros | Frontend Engineer" />
    <meta
      property="og:description"
      content="Frontend Engineer with 5+ years building performant, accessible web applications."
    />
    <meta property="og:url" content="https://mauroviveros.com.ar" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Mauro Viveros | Frontend Engineer" />
    <meta
      name="twitter:description"
      content="Frontend Engineer with 5+ years building performant, accessible web applications."
    />

    <Font cssVariable="--font-jetbrains-mono" preload />
  </head>
  <body>
    <Background />
    <Header />

    <main id="main">
      <slot />
    </main>
  </body>
</html>
