---
import TerminalWindow from '@/components/ui/TerminalWindow.astro';

const segments = [
  { text: '$ ', className: 'text-primary' },
  {
    text: 'cat developer.config.ts ',
    className: 'text-foreground',
    pauseAfter: 1000,
  },
  { text: '\n{\n', className: 'text-code-punct' },
  { text: '  name', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Mauro Viveros"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  role', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Frontend Engineer"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  location', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Buenos Aires, Argentina"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  focus', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '[\n', className: 'text-code-punct' },
  { text: '    "UX",\n', className: 'text-code-string' },
  { text: '    "DX",\n', className: 'text-code-string' },
  { text: '    "Testing",\n', className: 'text-code-string' },
  { text: '    "Accessibility",\n', className: 'text-code-string' },
  { text: '    "Performance",\n', className: 'text-code-string' },
  { text: '    "Scalable UI"\n', className: 'text-code-string' },
  { text: '  ],\n', className: 'text-code-punct' },
  { text: '  experience', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"5+ years"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  available', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: 'true', className: 'text-code-boolean' },
  { text: '\n}', className: 'text-code-punct' },
];
---

<TerminalWindow title="mauroviveros@portfolio">
  <pre
    id="terminal-content"
    class="m-0 overflow-x-auto font-mono text-sm leading-relaxed whitespace-pre-wrap">
    {segments.map((seg) => (
      <span class={seg.className}>{seg.text}</span>
    ))}
  </pre>

  <script define:vars={{ segments }}>
    const pre = document.getElementById('terminal-content');
    if (!pre) throw new Error('terminal-content not found');

    const SPEED = 15;
    let segIdx = 0;
    let charIdx = 0;

    const cursor = document.createElement('span');
    cursor.className =
      'inline-block h-[1em] w-[.55ch] animate-blink align-text-bottom bg-current animation-duration-[1.05s] animate-ease-in-out animate-iteration-count-infinite';
    cursor.setAttribute('aria-hidden', 'true');

    function appendChar(ch, cls) {
      const span = document.createElement('span');
      if (cls) span.className = cls;
      span.textContent = ch;
      pre.insertBefore(span, cursor);
    }

    function typeNext() {
      if (segIdx >= segments.length) return;

      const seg = segments[segIdx];

      if (charIdx >= seg.text.length) {
        charIdx = 0;
        segIdx++;
        setTimeout(typeNext, SPEED);
        return;
      }

      const isLast = charIdx === seg.text.length - 1;
      appendChar(seg.text[charIdx], seg.className);
      charIdx++;

      if (isLast && seg.pauseAfter) {
        setTimeout(typeNext, seg.pauseAfter);
      } else {
        setTimeout(typeNext, SPEED);
      }
    }

    // Clear static fallback, place cursor, animate
    pre.innerHTML = '';
    pre.appendChild(cursor);
    typeNext();
  </script>
</TerminalWindow>
