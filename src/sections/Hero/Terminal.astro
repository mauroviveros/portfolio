---
import TerminalWindow from '@/components/ui/TerminalWindow.astro';

import TerminalTypewriter from './TerminalTypewriter';

const segments = [
  { text: '$ ', className: 'text-primary' },
  {
    text: 'cat developer.config.ts ',
    className: 'text-foreground',
    pauseAfter: 1000,
  },
  { text: '\n{\n', className: 'text-code-punct' },
  { text: '  name', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Mauro Viveros"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  role', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Frontend Engineer"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  location', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"Buenos Aires, Argentina"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  focus', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '[\n', className: 'text-code-punct' },
  { text: '    "UX",\n', className: 'text-code-string' },
  { text: '    "DX",\n', className: 'text-code-string' },
  { text: '    "Testing",\n', className: 'text-code-string' },
  { text: '    "Accessibility",\n', className: 'text-code-string' },
  { text: '    "Performance",\n', className: 'text-code-string' },
  { text: '    "Scalable UI"\n', className: 'text-code-string' },
  { text: '  ],\n', className: 'text-code-punct' },
  { text: '  experience', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: '"5+ years"', className: 'text-code-string' },
  { text: ',\n', className: 'text-code-punct' },
  { text: '  available', className: 'text-code-key' },
  { text: ': ', className: 'text-code-punct' },
  { text: 'true', className: 'text-code-boolean' },
  { text: '\n}', className: 'text-code-punct' },
];
---

<TerminalWindow title="mauroviveros@portfolio">
  <TerminalTypewriter {segments} speed={15} client:only="react" />
</TerminalWindow>
