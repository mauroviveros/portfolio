---
import type { HTMLAttributes } from 'astro/types';
import { Icon } from 'astro-icon/components';

import Button from '@/components/starwind/button';

import Heading from './Heading.astro';
import Mantra from './Mantra.astro';

interface Props extends HTMLAttributes<'section'> {}
const { class: className, ...props } = Astro.props;
---

<section
  aria-labelledby="hero-title"
  class:list={[
    'relative mx-auto px-8',
    'max-w-5xl lg:max-w-6xl',
    'flex flex-col justify-evenly gap-4 sm:justify-center',
    'pt-12 pb-16 sm:pt-4 sm:pb-20',
    className,
  ]}
  {...props}
>
  <div>
    <p
      class:list={['text-code-comment font-code inline-flex flex-col text-sm']}
    >
      <span>// Engineer focused on building</span>
      <span>// efficient and valuable experiences</span>
    </p>
    <p class="font-code flex space-x-2 text-sm sm:text-base">
      <span class="text-code-key">const</span>
      <span class="text-foreground">developer</span>
      <span class="text-code-punct">&equals;</span>
      <span class="text-code-string m-0">&quot;Mauro Daniel Viveros&quot;</span>
      <span class="text-code-punct">;</span>
    </p>
    <p class="font-code flex space-x-2 text-sm sm:text-base">
      <span class="text-code-key">const</span>
      <span class="text-foreground">role</span>
      <span class="text-code-punct">&equals;</span>
      <span class="text-code-string m-0">&quot;Frontend Developer&quot;</span>
      <span class="text-code-punct">;</span>
    </p>

    <Heading />
  </div>

  <div>
    <p
      class="text-muted-foreground max-w-xl text-base leading-relaxed sm:text-lg"
    >
      Frontend Engineer with 5+ years of experience creating scalable web
      applications, design systems, internal tools and developer-focused
      solutions.
      <span class="text-foreground">
        Building products people enjoy and developers enjoy maintaining.
      </span>
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <Button variant="primary">
        View my Work
        <Icon name="tabler:arrow-right" class="ml-2 h-4 w-4" />
      </Button>

      <Button variant="outline">Contact me</Button>
    </div>

    <p class="font-code text-code-comment mt-8 text-sm">
      // Let's build something amazing together 🚀
    </p>
  </div>

  <Mantra class="top-2/12 right-6 hidden sm:block md:right-2/12" />
</section>
